#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "${repo_root}"
export UV_CACHE_DIR="${UV_CACHE_DIR:-${repo_root}/.uv-cache}"

if command -v uv >/dev/null 2>&1; then
  exec uv run dp enforce pre-commit --policy dp-policy.json
fi

if command -v dp >/dev/null 2>&1; then
  exec dp enforce pre-commit --policy dp-policy.json
fi

echo "dp enforcement failed: neither 'uv' nor 'dp' command is available." >&2
exit 127
