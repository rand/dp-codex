#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
cd "${repo_root}"
export UV_CACHE_DIR="${UV_CACHE_DIR:-${repo_root}/.uv-cache}"
timeout_seconds="${DP_HOOK_TIMEOUT_SECONDS:-120}"

run_with_timeout() {
  if command -v timeout >/dev/null 2>&1; then
    exec timeout "${timeout_seconds}" "$@"
  fi
  exec "$@"
}

if command -v uv >/dev/null 2>&1; then
  run_with_timeout uv run dp enforce pre-commit --policy dp-policy.json
fi

if command -v dp >/dev/null 2>&1; then
  run_with_timeout dp enforce pre-commit --policy dp-policy.json
fi

echo "dp enforcement failed: neither 'uv' nor 'dp' command is available." >&2
exit 127
