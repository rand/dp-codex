{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "artifact_paths": {
      "additionalProperties": false,
      "properties": {
        "campaign": {
          "type": "string"
        },
        "evidence_plans": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "goals": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "loop": {
          "type": "string"
        },
        "needs_refinement": {
          "type": "string"
        }
      },
      "required": [
        "campaign",
        "loop",
        "goals",
        "evidence_plans",
        "needs_refinement"
      ],
      "type": "object"
    },
    "compiler": {
      "additionalProperties": false,
      "properties": {
        "llm": {
          "const": false
        },
        "mode": {
          "const": "deterministic_markdown_signals"
        },
        "nodes": {
          "items": {
            "$ref": "#/$defs/compiler_node"
          },
          "type": "array"
        },
        "ready_for_implementation": {
          "const": false
        },
        "semantic_planning": {
          "const": false
        },
        "summary": {
          "$ref": "#/$defs/compiler_summary"
        }
      },
      "required": [
        "mode",
        "llm",
        "semantic_planning",
        "ready_for_implementation",
        "summary",
        "nodes"
      ],
      "type": "object"
    },
    "compiler_node": {
      "additionalProperties": false,
      "properties": {
        "classification": {
          "enum": [
            "implementation",
            "evidence",
            "decision",
            "context",
            "unknown"
          ],
          "type": "string"
        },
        "line": {
          "type": "integer"
        },
        "refinement_state": {
          "enum": [
            "implementation_candidate",
            "evidence_candidate",
            "needs_decision",
            "needs_validator",
            "needs_specification"
          ],
          "type": "string"
        },
        "routes": {
          "items": {
            "enum": [
              "needs_decision",
              "needs_specification",
              "needs_validator"
            ],
            "type": "string"
          },
          "type": "array"
        },
        "section_id": {
          "type": "string"
        },
        "signals": {
          "$ref": "#/$defs/compiler_signals"
        },
        "title": {
          "type": "string"
        }
      },
      "required": [
        "section_id",
        "title",
        "line",
        "classification",
        "refinement_state",
        "routes",
        "signals"
      ],
      "type": "object"
    },
    "compiler_signals": {
      "additionalProperties": false,
      "properties": {
        "blockers": {
          "$ref": "#/$defs/signal_array"
        },
        "decisions": {
          "$ref": "#/$defs/signal_array"
        },
        "dependencies": {
          "$ref": "#/$defs/signal_array"
        },
        "evidence": {
          "$ref": "#/$defs/signal_array"
        },
        "requirements": {
          "$ref": "#/$defs/signal_array"
        }
      },
      "required": [
        "requirements",
        "evidence",
        "decisions",
        "blockers",
        "dependencies"
      ],
      "type": "object"
    },
    "compiler_summary": {
      "additionalProperties": false,
      "properties": {
        "decision_nodes": {
          "type": "integer"
        },
        "dependency_cues": {
          "type": "integer"
        },
        "evidence_candidates": {
          "type": "integer"
        },
        "implementation_candidates": {
          "type": "integer"
        },
        "needs_specification": {
          "type": "integer"
        },
        "needs_validator": {
          "type": "integer"
        },
        "sections": {
          "type": "integer"
        }
      },
      "required": [
        "sections",
        "implementation_candidates",
        "evidence_candidates",
        "decision_nodes",
        "needs_specification",
        "needs_validator",
        "dependency_cues"
      ],
      "type": "object"
    },
    "error": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "path": {
          "type": "string"
        }
      },
      "required": [
        "code",
        "path",
        "message"
      ],
      "type": "object"
    },
    "marker": {
      "additionalProperties": false,
      "properties": {
        "reason": {
          "type": "string"
        },
        "route": {
          "enum": [
            "needs_decision",
            "needs_specification",
            "needs_validator"
          ],
          "type": "string"
        }
      },
      "required": [
        "route",
        "reason"
      ],
      "type": "object"
    },
    "primary_spec": {
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string"
        },
        "sha256": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "type": "string"
        }
      },
      "required": [
        "path",
        "sha256"
      ],
      "type": "object"
    },
    "signal_array": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "section": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "level": {
          "type": "integer"
        },
        "line": {
          "type": "integer"
        },
        "title": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "title",
        "level",
        "line"
      ],
      "type": "object"
    }
  },
  "oneOf": [
    {
      "additionalProperties": true,
      "properties": {
        "artifacts": {
          "$ref": "#/$defs/artifact_paths"
        },
        "campaign_id": {
          "type": "string"
        },
        "command": {
          "const": "campaign.init"
        },
        "compiler": {
          "$ref": "#/$defs/compiler"
        },
        "loop_id": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "needs_refinement": {
          "const": true
        },
        "ok": {
          "const": true
        },
        "primary_spec": {
          "$ref": "#/$defs/primary_spec"
        },
        "refinement_markers": {
          "items": {
            "$ref": "#/$defs/marker"
          },
          "type": "array"
        },
        "sections": {
          "items": {
            "$ref": "#/$defs/section"
          },
          "type": "array"
        }
      },
      "required": [
        "ok",
        "command",
        "campaign_id",
        "loop_id",
        "needs_refinement",
        "primary_spec",
        "sections",
        "compiler",
        "refinement_markers",
        "artifacts",
        "lint",
        "message"
      ],
      "type": "object"
    },
    {
      "additionalProperties": false,
      "properties": {
        "command": {
          "const": "campaign.init"
        },
        "error": {
          "$ref": "#/$defs/error"
        },
        "ok": {
          "const": false
        }
      },
      "required": [
        "ok",
        "command",
        "error"
      ],
      "type": "object"
    }
  ],
  "title": "Campaign init output"
}
