{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "error": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "path": {
          "type": "string"
        }
      },
      "required": [
        "code",
        "path",
        "message"
      ],
      "type": "object"
    }
  },
  "additionalProperties": true,
  "properties": {
    "agent": {
      "type": "string"
    },
    "autonomous": {
      "const": false
    },
    "claim": {
      "type": "object"
    },
    "codex_goal": {
      "type": "string"
    },
    "command": {
      "const": "agent.launch"
    },
    "driver": {
      "type": "string"
    },
    "error": {
      "$ref": "#/$defs/error"
    },
    "goal_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "goal_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "launched": {
      "const": false
    },
    "mode": {
      "const": "supervised_goal_launch"
    },
    "ok": {
      "type": "boolean"
    },
    "start": {
      "type": "object"
    },
    "stop_conditions": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "supervised": {
      "type": "boolean"
    }
  },
  "required": [
    "ok",
    "command",
    "mode",
    "driver",
    "supervised",
    "autonomous",
    "launched",
    "stop_conditions"
  ],
  "title": "Agent launch output",
  "type": "object"
}
