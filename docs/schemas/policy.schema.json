{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "dp policy configuration",
  "type": "object",
  "required": ["mode"],
  "properties": {
    "mode": {
      "type": "string",
      "enum": ["strict", "guided", "minimal"]
    },
    "overrides": {
      "type": "object",
      "additionalProperties": {
        "type": "boolean"
      }
    }
  },
  "additionalProperties": false
}
