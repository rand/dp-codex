{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["valid", "loop_id", "errors", "warnings"],
  "additionalProperties": false,
  "properties": {
    "valid": {
      "type": "boolean"
    },
    "loop_id": {
      "type": ["string", "null"]
    },
    "errors": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/finding"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/finding"
      }
    }
  },
  "$defs": {
    "finding": {
      "type": "object",
      "required": ["code", "path", "message"],
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "message": {
          "type": "string"
        }
      }
    }
  }
}
