{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "dp verify output",
  "type": "object",
  "required": ["outcome", "levels"],
  "properties": {
    "ok": {
      "type": "boolean"
    },
    "error": {
      "type": "string"
    },
    "outcome": {
      "type": "string",
      "enum": ["verified", "incomplete", "failed"]
    },
    "levels": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["level", "status", "passed", "total", "details"],
        "properties": {
          "level": {
            "type": "string",
            "enum": ["truths", "artifacts", "links"]
          },
          "status": {
            "type": "string",
            "enum": ["verified", "incomplete", "failed"]
          },
          "passed": {
            "type": "integer",
            "minimum": 0
          },
          "total": {
            "type": "integer",
            "minimum": 0
          },
          "details": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
