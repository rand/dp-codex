{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "assertion_result": {
      "additionalProperties": false,
      "properties": {
        "message": {
          "type": "string"
        },
        "ok": {
          "type": "boolean"
        },
        "path": {
          "type": "string"
        },
        "type": {
          "type": "string"
        }
      },
      "required": [
        "type",
        "path",
        "ok",
        "message"
      ],
      "type": "object"
    },
    "artifact": {
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string"
        },
        "written": {
          "type": "boolean"
        }
      },
      "required": [
        "path",
        "written"
      ],
      "type": "object"
    },
    "check_result": {
      "additionalProperties": false,
      "properties": {
        "argv": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "assertions": {
          "items": {
            "$ref": "#/$defs/assertion_result"
          },
          "type": "array"
        },
        "cwd": {
          "type": "string"
        },
        "error": {
          "anyOf": [
            {
              "$ref": "#/$defs/error"
            },
            {
              "type": "null"
            }
          ]
        },
        "exit_code": {
          "type": [
            "integer",
            "null"
          ]
        },
        "id": {
          "type": "string"
        },
        "ok": {
          "type": "boolean"
        },
        "stderr": {
          "type": "string"
        },
        "stdout": {
          "type": "string"
        },
        "status": {
          "enum": [
            "passed",
            "failed",
            "timed_out",
            "error"
          ],
          "type": "string"
        },
        "timeout_seconds": {
          "type": "integer"
        }
      },
      "required": [
        "id",
        "ok",
        "status",
        "argv",
        "cwd",
        "timeout_seconds",
        "exit_code",
        "stdout",
        "stderr",
        "assertions",
        "error"
      ],
      "type": "object"
    },
    "error": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "path": {
          "type": "string"
        }
      },
      "required": [
        "code",
        "path",
        "message"
      ],
      "type": "object"
    },
    "evidence_plan_source": {
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string"
        },
        "sha256": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "path",
        "sha256"
      ],
      "type": "object"
    },
    "finding": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "path": {
          "type": "string"
        }
      },
      "required": [
        "code",
        "path",
        "message"
      ],
      "type": "object"
    },
    "lint": {
      "additionalProperties": false,
      "properties": {
        "errors": {
          "items": {
            "$ref": "#/$defs/finding"
          },
          "type": "array"
        },
        "evidence_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "goal_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "valid": {
          "type": "boolean"
        },
        "warnings": {
          "items": {
            "$ref": "#/$defs/finding"
          },
          "type": "array"
        }
      },
      "required": [
        "valid",
        "evidence_id",
        "goal_id",
        "errors",
        "warnings"
      ],
      "type": "object"
    },
    "summary": {
      "additionalProperties": false,
      "properties": {
        "errored": {
          "type": "integer"
        },
        "failed": {
          "type": "integer"
        },
        "passed": {
          "type": "integer"
        },
        "timed_out": {
          "type": "integer"
        },
        "total": {
          "type": "integer"
        }
      },
      "required": [
        "total",
        "passed",
        "failed",
        "timed_out",
        "errored"
      ],
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "checks": {
      "items": {
        "$ref": "#/$defs/check_result"
      },
      "type": "array"
    },
    "artifact": {
      "anyOf": [
        {
          "$ref": "#/$defs/artifact"
        },
        {
          "type": "null"
        }
      ]
    },
    "command": {
      "const": "evidence.run"
    },
    "error": {
      "anyOf": [
        {
          "$ref": "#/$defs/error"
        },
        {
          "type": "null"
        }
      ]
    },
    "evidence_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "evidence_plan": {
      "$ref": "#/$defs/evidence_plan_source"
    },
    "goal_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "lint": {
      "$ref": "#/$defs/lint"
    },
    "ok": {
      "type": "boolean"
    },
    "summary": {
      "$ref": "#/$defs/summary"
    }
  },
  "required": [
    "ok",
    "command",
    "evidence_id",
    "evidence_plan",
    "goal_id",
    "lint",
    "checks",
    "summary",
    "error",
    "artifact"
  ],
  "title": "Evidence run output",
  "type": "object"
}
