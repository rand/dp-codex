{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "evidence": {
      "additionalProperties": false,
      "properties": {
        "argv": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "minItems": 1,
          "type": "array"
        },
        "kind": {
          "const": "registered_command"
        },
        "rationale": {
          "type": "string"
        }
      },
      "required": [
        "kind",
        "argv"
      ],
      "type": "object"
    },
    "node": {
      "additionalProperties": false,
      "properties": {
        "allowed_paths": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "decisions": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "dependencies": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "evidence": {
          "items": {
            "$ref": "#/$defs/evidence"
          },
          "type": "array"
        },
        "goal_id": {
          "pattern": "^GOAL-[A-Za-z0-9][A-Za-z0-9_.-]*$",
          "type": "string"
        },
        "non_goals": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "objective": {
          "type": "string"
        },
        "rationale": {
          "type": "string"
        },
        "read_first": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "requirements": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "goal_id"
      ],
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "campaign_id": {
      "pattern": "^CAMPAIGN-[A-Za-z0-9][A-Za-z0-9_.-]*$",
      "type": "string"
    },
    "campaign_rationale": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    },
    "model": {
      "minLength": 1,
      "type": "string"
    },
    "nodes": {
      "items": {
        "$ref": "#/$defs/node"
      },
      "minItems": 1,
      "type": "array"
    },
    "prompt_hash": {
      "pattern": "^sha256:[0-9a-f]{64}$",
      "type": "string"
    },
    "provider": {
      "minLength": 1,
      "type": "string"
    },
    "provider_source": {
      "enum": [
        "calling_agent",
        "environment",
        "explicit_config"
      ],
      "type": "string"
    },
    "schema_version": {
      "const": "0.1"
    }
  },
  "required": [
    "schema_version",
    "campaign_id",
    "prompt_hash",
    "provider",
    "provider_source",
    "model",
    "created_at",
    "nodes"
  ],
  "title": "Campaign refine LLM response",
  "type": "object"
}
